{
  "name": "plat",
  "version": "0.1.0",
  "description": "Type-safe API framework built on Zod with generated client proxies and OpenAPI",
  "type": "module",
  "author": {
    "name": "Torin Halsted",
    "email": "modularizer@gmail.com",
    "url": "https://github.com/modularizer"
  },
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/modularizer/plat.git"
  },
  "bugs": {
    "url": "https://github.com/modularizer/plat/issues"
  },
  "homepage": "https://github.com/modularizer/plat",
  "bin": {
    "plat": "bin/plat.js"
  },
  "main": "../dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "../dist"
  ],
  "scripts": {
    "build": "../node_modules/.bin/tsc",
    "typecheck": "../node_modules/.bin/tsc --noEmit && tsc -p tsconfig.scripts.json",
    "gen:samples": "../node_modules/.bin/tsx scripts/gen-samples.ts",
    "test": "../node_modules/.bin/tsx scripts/gen-samples.ts && jest",
    "test:watch": "../node_modules/.bin/jest --watch",
    "test:coverage": "../node_modules/.bin/jest --coverage",
    "gen": "cd ../sample && npm run gen",
    "gen:openapi": "../node_modules/.bin/tsx scripts/gen-openapi.ts",
    "gen:openapi-spec": "../node_modules/.bin/tsx scripts/gen-openapi-spec.ts",
    "gen:client": "../node_modules/.bin/tsx scripts/gen-client-openapi.ts",
    "gen:cli": "../node_modules/.bin/tsx scripts/gen-cli.ts",
    "env:init": "../node_modules/.bin/tsx scripts/init-env.ts",
    "env:secret": "../node_modules/.bin/tsx scripts/update-jwt-secret.ts"
  },
  "keywords": [
    "zod",
    "typescript",
    "api",
    "openapi",
    "client",
    "framework",
    "proxy",
    "rpc"
  ],
  "dependencies": {
    "chokidar": "^5.0.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.0",
    "redoc-express": "^2.1.3",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-morph": "^23.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
