{
  "name": "@modularizer/plat",
  "version": "0.4.0",
  "description": "Protocol and Language Agnostic Tooling Yielding Universal Semantics",
  "type": "module",
  "author": {
    "name": "Torin Halsted",
    "email": "modularizer@gmail.com",
    "url": "https://github.com/modularizer"
  },
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/modularizer/plat.git"
  },
  "bugs": {
    "url": "https://github.com/modularizer/plat/issues"
  },
  "homepage": "https://github.com/modularizer/plat",
  "bin": {
    "plat": "bin/z2.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client-entry.js",
      "types": "./dist/client-entry.d.ts"
    },
    "./client-server": {
      "import": "./dist/client-server-entry.js",
      "types": "./dist/client-server-entry.d.ts"
    },
    "./python-browser": {
      "import": "./dist/python-browser-entry.js",
      "types": "./dist/python-browser-entry.d.ts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsx scripts/gen-python-browser-sources.ts && tsc && tsx scripts/rewrite-relative-imports.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "gen:samples": "tsx scripts/gen-samples.ts",
    "test": "tsx scripts/gen-samples.ts && jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "gen": "cd ../sample && npm run gen",
    "gen:openapi": "tsx scripts/gen-openapi.ts",
    "gen:openapi-spec": "tsx scripts/gen-openapi-spec.ts",
    "gen:client": "tsx scripts/gen-client-openapi.ts",
    "gen:cli": "tsx scripts/gen-cli.ts",
    "env:init": "tsx scripts/init-env.ts",
    "env:secret": "tsx scripts/update-jwt-secret.ts"
  },
  "keywords": [
    "zod",
    "typescript",
    "api",
    "openapi",
    "client",
    "framework",
    "proxy",
    "rpc"
  ],
  "dependencies": {
    "@roamhq/wrtc": "^0.10.0",
    "chokidar": "^5.0.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.0",
    "mqtt": "^5.15.1",
    "redoc-express": "^2.1.3",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.18.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-morph": "^23.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
