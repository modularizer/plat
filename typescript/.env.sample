# PLAT Server Configuration
# Copy this file to .env and update values as needed

# Server Port (default: 3000)
PLAT_SERVER_PORT=3000

# Server Host (default: localhost)
PLAT_SERVER_HOST=localhost

# Protocol for logging (default: http)
PLAT_PROTOCOL=http

# Error Exposure Level
# Options: 'none' | 'message' | 'full'
# - 'none': only { error: 'Internal server error' }
# - 'message': { error: 'Original error message' }
# - 'full': { error: message, stack, data, ... }
PLAT_ERROR_EXPOSURE=message

# JWT Authentication Secret (required for JWT auth)
JWT_SECRET=your-secret-key-change-in-production

# JWT Token Expiration (default: 24h)
JWT_EXPIRES_IN=24h

# JWT Refresh Token Expiration (default: 7d)
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
# Options: 'true' | 'false' | comma-separated origins
PLAT_CORS=true

# Enable Swagger UI Documentation (default: true)
PLAT_SWAGGER=true

# Enable ReDoc Documentation (default: true)
PLAT_REDOC=true

# Default Authentication Mode (default: public)
PLAT_DEFAULT_AUTH=public

# Rate Limiting - Global Config
# Max tokens available
PLAT_RATE_LIMIT_MAX_BALANCE=100
# Milliseconds between refills
PLAT_RATE_LIMIT_FILL_INTERVAL=1000
# Tokens to add per interval
PLAT_RATE_LIMIT_FILL_AMOUNT=10

# Rate Limiting - Retry After Headers
# Options: 'true' | 'false'
PLAT_RATE_LIMIT_HEADERS=true

# Token Limiting - Default Config
# Max tokens available
PLAT_TOKEN_LIMIT_MAX_BALANCE=10000
# Milliseconds between refills
PLAT_TOKEN_LIMIT_FILL_INTERVAL=1000
# Tokens to add per interval
PLAT_TOKEN_LIMIT_FILL_AMOUNT=100

# Token Limiting - Response Cost Header
# Options: 'true' | 'false'
PLAT_TOKEN_COST_HEADER=true

# Caching
# Enable cache header in responses
PLAT_CACHE_HEADER=true

# Database Configuration (optional, for future use)
DATABASE_URL=

# Logging Level
# Options: 'debug' | 'info' | 'warn' | 'error'
PLAT_LOG_LEVEL=info

# Node Environment
NODE_ENV=development
