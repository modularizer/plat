# PLAT Authority Server — Environment Configuration
# Copy this to .env and customize for your environment

# Server
PORT=3000
NODE_ENV=development
AUTHORITY_URL=http://localhost:3000
# Optional: treat hosts ending in this base domain as subdomain-style names.
# Example: whiteboard.alice.plat.local => namespace "alice", subpath "whiteboard"
# AUTHORITY_SUBDOMAIN_BASE_DOMAIN=plat.local
# Optional: allow origin-scoped namespace ownership across multiple marketplace fronts.
# Examples:
#   apple.pear.com/donkey
#   notes.donkey.apple.pear.com
# Both resolve to ownership key "apple.pear.com::donkey"
# AUTHORITY_ALLOWED_ORIGINS=apple.pear.com,broswerver.com,browservable.com,coolsite.ai
# Optional: comma-separated namespace globs that can never be claimed.
# Supports * wildcards, for example:
# AUTHORITY_DISALLOWED_NAMESPACE_GLOBS=admin-*,*-internal,staging
# Admin dashboard host port (docker compose admin profile)
ADMIN_PORT=3001

# PostgreSQL
POSTGRES_USER=plat
POSTGRES_PASSWORD=plat_development_password
POSTGRES_DB=plat_authority

# Host authentication mode
# insecure_token_sub: token value is treated as host google_sub (dev only)
# google_tokeninfo: validates Google ID token via tokeninfo endpoint
HOST_AUTH_MODE=insecure_token_sub
# Shared Google client ID (used for host token verification and OAuth)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Connect abuse control
# CONNECT_RATE_LIMIT_PER_30S=500
# WS_HOST_MSG_RATE_LIMIT_PER_30S=300
# WS_PRESENCE_MSG_RATE_LIMIT_PER_30S=300
# OAUTH_RATE_LIMIT_PER_30S=30
# TRACEBACK_MAX_LINES=0

# OAuth Redirect Framework (no UI required)
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauthCallback
# OAUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:5173,https://app.example.com

# OAuth-backed admin sessions
# ADMIN_GOOGLE_SUBS=google-sub-1,google-sub-2
# ADMIN_SESSION_TTL_SECONDS=43200
# ADMIN_SESSION_SECRET=replace-me-with-a-long-random-secret

# Database connection string (auto-generated if not set)
# DATABASE_URL=postgresql://plat:plat_development_password@postgres:5432/plat_authority

# Storage Adapter
# Options: memory, json, yaml, drizzle (default: drizzle)
# STORAGE_TYPE=json
# STORAGE_PATH=/app/data/servers.json
